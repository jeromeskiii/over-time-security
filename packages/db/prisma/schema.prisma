generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum LeadStatus {
  NEW       @map("new")
  CONTACTED @map("contacted")
  QUOTED    @map("quoted")
  WON       @map("won")
  LOST      @map("lost")
}

enum GuardStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum ShiftStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentType {
  THEFT
  VANDALISM
  TRESPASS
  MEDICAL
  FIRE
  SUSPICIOUS_ACTIVITY
  OTHER
}

enum EventType {
  GUARD_CHECKED_IN
  GUARD_CHECKED_OUT
  PATROL_STARTED
  PATROL_CHECKPOINT_SCANNED
  PATROL_MISSED_CHECKPOINT
  INCIDENT_CREATED
  INCIDENT_ESCALATED
  SHIFT_STARTED
  SHIFT_ENDED
  SHIFT_NO_SHOW
  REPORT_GENERATED
  LEAD_CREATED
  COMPLIANCE_CALCULATED
}

enum ActorType {
  GUARD
  SUPERVISOR
  ADMIN
  SYSTEM
  CLIENT
}

enum NotificationChannel {
  SMS
  EMAIL
  PUSH
}

enum NotificationStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
}

enum RiskLevel {
  NORMAL
  AT_RISK
  CRITICAL
}

enum ReportStatus {
  PENDING
  AI_GENERATED
  SUPERVISOR_REVIEW
  APPROVED
  SENT
}

model Lead {
  id           String     @id @default(cuid())
  name         String
  email        String
  phone        String
  company      String?
  serviceType  String     @map("service_type")
  message      String
  status       LeadStatus @default(NEW)
  estimateData Json?      @map("estimate_data")
  createdAt    DateTime   @default(now()) @map("created_at")

  @@map("leads")
}

model Guard {
  id            String      @id @default(cuid())
  name          String
  licenseNumber String      @unique @map("license_number")
  phone         String
  status        GuardStatus @default(ACTIVE)
  createdAt     DateTime    @default(now()) @map("created_at")
  shifts        Shift[]
  incidents     Incident[]

  @@map("guards")
}

model Client {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  createdAt DateTime @default(now()) @map("created_at")
  sites     Site[]

  @@map("clients")
}

model Site {
  id               String            @id @default(cuid())
  clientId         String            @map("client_id")
  client           Client            @relation(fields: [clientId], references: [id])
  location         String
  instructions     String?
  timezone         String            @default("America/Los_Angeles")
  createdAt        DateTime          @default(now()) @map("created_at")
  shifts           Shift[]
  incidents        Incident[]
  checkIns         CheckIn[]
  patrolLogs       PatrolLog[]
  complianceScores ComplianceScore[]

  @@map("sites")
}

model Shift {
  id         String      @id @default(cuid())
  guardId    String      @map("guard_id")
  guard      Guard       @relation(fields: [guardId], references: [id])
  siteId     String      @map("site_id")
  site       Site        @relation(fields: [siteId], references: [id])
  startTime  DateTime    @map("start_time")
  endTime    DateTime    @map("end_time")
  status     ShiftStatus @default(SCHEDULED)
  riskLevel  RiskLevel   @default(NORMAL) @map("risk_level")
  createdAt  DateTime    @default(now()) @map("created_at")
  checkIns   CheckIn[]
  patrolLogs PatrolLog[]
  incidents  Incident[]

  @@map("shifts")
}

model Incident {
  id          String           @id @default(cuid())
  guardId     String           @map("guard_id")
  guard       Guard            @relation(fields: [guardId], references: [id])
  siteId      String           @map("site_id")
  site        Site             @relation(fields: [siteId], references: [id])
  shiftId     String?          @map("shift_id")
  shift       Shift?           @relation(fields: [shiftId], references: [id])
  type        IncidentType     @default(OTHER)
  description String
  severity    IncidentSeverity @default(LOW)
  photoKeys   String[]         @default([]) @map("photo_keys")
  occurredAt  DateTime         @map("occurred_at")
  createdAt   DateTime         @default(now()) @map("created_at")
  report      Report?

  @@map("incidents")
}

model Report {
  id         String       @id @default(cuid())
  incidentId String       @unique @map("incident_id")
  incident   Incident     @relation(fields: [incidentId], references: [id])
  content    String
  pdfKey     String?      @map("pdf_key")
  sentAt     DateTime?    @map("sent_at")
  sentTo     String?      @map("sent_to")
  status     ReportStatus @default(PENDING) @map("status")
  createdAt  DateTime     @default(now()) @map("created_at")

  @@map("reports")
}

// guardId derived via shift.guard — no direct FK to avoid update anomalies
model CheckIn {
  id        String   @id @default(cuid())
  shiftId   String   @map("shift_id")
  shift     Shift    @relation(fields: [shiftId], references: [id])
  siteId    String   @map("site_id")
  site      Site     @relation(fields: [siteId], references: [id])
  timestamp DateTime
  latitude  Float?
  longitude Float?
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("check_ins")
}

// guardId derived via shift.guard — no direct FK to avoid update anomalies
model PatrolLog {
  id             String   @id @default(cuid())
  shiftId        String   @map("shift_id")
  shift          Shift    @relation(fields: [shiftId], references: [id])
  siteId         String   @map("site_id")
  site           Site     @relation(fields: [siteId], references: [id])
  checkpointName String   @map("checkpoint_name")
  timestamp      DateTime
  latitude       Float?
  longitude      Float?
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("patrol_logs")
}

model Event {
  id         String    @id @default(cuid())
  type       EventType
  entityType String    @map("entity_type")
  entityId   String    @map("entity_id")
  payload    Json      @default("{}")
  actorId    String?   @map("actor_id")
  actorType  ActorType @default(SYSTEM) @map("actor_type")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([type])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([actorId])
  @@map("events")
}

model ComplianceScore {
  id                String   @id @default(cuid())
  siteId            String   @map("site_id")
  site              Site     @relation(fields: [siteId], references: [id])
  periodStart       DateTime @map("period_start")
  periodEnd         DateTime @map("period_end")
  patrolCompletion  Float    @map("patrol_completion")
  incidentFrequency Float    @map("incident_frequency")
  missedCheckIns    Float    @map("missed_check_ins")
  reportTimeliness  Float    @map("report_timeliness")
  overallScore      Float    @map("overall_score")
  grade             String
  calculatedAt      DateTime @default(now()) @map("calculated_at")

  @@index([siteId, periodEnd])
  @@index([calculatedAt])
  @@map("compliance_scores")
}

model Notification {
  id            String              @id @default(cuid())
  channel       NotificationChannel
  recipientId   String              @map("recipient_id")
  recipientType String              @map("recipient_type")
  subject       String?
  body          String
  metadata      Json                @default("{}")
  status        NotificationStatus  @default(PENDING)
  sentAt        DateTime?           @map("sent_at")
  failReason    String?             @map("fail_reason")
  eventId       String?             @map("event_id")
  createdAt     DateTime            @default(now()) @map("created_at")

  @@index([recipientId, recipientType])
  @@index([status])
  @@index([createdAt])
  @@map("notifications")
}
