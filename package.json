{
  "name": "over-time-security",
  "private": true,
  "version": "0.0.0",
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": "20.19.x",
    "pnpm": ">=10"
  },
  "volta": {
    "node": "20.19.0",
    "pnpm": "10.32.1"
  },
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@ots/web",
    "dev:ops": "turbo dev --filter=@ots/ops",
    "dev:guard": "turbo dev --filter=@ots/guard",
    "postinstall": "pnpm --filter @ots/db db:generate",
    "build": "pnpm --filter @ots/web build",
    "build:all": "turbo build",
    "lint": "turbo lint",
    "typecheck": "pnpm --filter @ots/web typecheck",
    "typecheck:web": "pnpm --filter @ots/web typecheck",
    "typecheck:all": "turbo typecheck",
    "clean": "turbo clean && rm -rf node_modules",
    "db:generate": "turbo db:generate --filter=@ots/db",
    "db:migrate": "turbo db:migrate --filter=@ots/db",
    "db:push": "turbo db:push --filter=@ots/db",
    "db:studio": "turbo db:studio --filter=@ots/db",
    "db:seed": "turbo db:seed --filter=@ots/db",
    "workers": "pnpm --filter @ots/automation run workers",
    "workers:dev": "pnpm --filter @ots/automation run workers:dev",
    "test": "turbo test",
    "env:verify": "node scripts/verify-env-schema.mjs"
  },
  "devDependencies": {
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "turbo": "^2.4.0",
    "typescript": "^5.8.2"
  }
}
