# PostgreSQL database URL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/overtime_security"

# Allow the Vite frontend origin to call /api/leads
FRONTEND_ORIGIN="http://localhost:3000"

# Auth settings for dashboard/guard/API protection
AUTH_COOKIE_SECRET="replace-with-long-random-secret"
ADMIN_ACCESS_PASSWORD="replace-with-admin-password"
GUARD_ACCESS_PASSWORD="replace-with-guard-password"
