# ── Web App ───────────────────────────────────────────────
# Required for the quote/contact form. Get a free key at https://web3forms.com
VITE_WEB3FORMS_KEY="YOUR_WEB3FORMS_ACCESS_KEY"

# ── Database ──────────────────────────────────────────────
DATABASE_URL="postgresql://ots:ots_dev_password@localhost:5432/overtime_security"

# ── Redis ─────────────────────────────────────────────────
# ⚠️ Production must use strong credentials — this is a dev default
REDIS_URL="redis://:ots_dev_password@localhost:6379"

# ── Auth ──────────────────────────────────────────────────
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3001"
JWT_SECRET="replace-with-32+char-random-secret"
ADMIN_EMAIL="admin@overtimesecurity.local"
ADMIN_PASSWORD="change-this-dev-password"

# ── Cross-App URLs ────────────────────────────────────────
WEB_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3001"

# ── AI (Gemini) ──────────────────────────────────────────
GEMINI_API_KEY="your-gemini-api-key"

# ── Email (Resend) ───────────────────────────────────────
RESEND_API_KEY="your-resend-api-key"
EMAIL_FROM="Over Time Security <noreply@overtimesecurity.com>"
DISPATCH_EMAIL="dispatch@overtimesecurity.com"

# ── SMS (Twilio) ─────────────────────────────────────────
TWILIO_ACCOUNT_SID="your-twilio-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_PHONE_NUMBER="+1234567890"

# ── AWS S3 ───────────────────────────────────────────────
AWS_ACCESS_KEY_ID="your-aws-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret"
AWS_REGION="us-west-2"
S3_BUCKET_NAME="ots-reports"

# ── Automation Tuning ────────────────────────────────────
CHECKPOINT_WINDOW_MINUTES="30"
NO_SHOW_THRESHOLD_MINUTES="30"
AI_MONTHLY_BUDGET_USD="100"

# ── Test Overrides (optional) ────────────────────────────
TEST_DATABASE_URL="postgresql://ots:ots_dev_password@localhost:5432/overtime_security_test"
TEST_REDIS_URL="redis://:ots_dev_password@localhost:6379"
